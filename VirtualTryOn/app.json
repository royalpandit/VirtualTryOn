{
  "expo": {
    "name": "oui",
    "slug": "oui",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/oui.jpg",
    "scheme": "oui",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/oui.jpg",
        "backgroundImage": "./assets/images/oui.jpg",
        "monochromeImage": "./assets/images/oui.jpg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yashvardhan0012.oui"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/oui.jpg"
    },
    "plugins": [
      "./plugins/withBuildConfig.js",
      "expo-router",
      "expo-image-picker",
      "expo-camera",
      ["expo-build-properties", { "android": { "usesCleartextTraffic": true } }],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/oui.jpg",
          "imageWidth": 320,
          "resizeMode": "cover",
          "backgroundColor": "#0f0f10",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "API_URL": "https://548b-2405-201-3016-9117-5c08-686b-ec91-421c.ngrok-free.app/api/try-on",
      "OUI_API_BASE_URL": "https://oui.corescent.in",
      "router": {},
      "eas": {
        "projectId": "f3e84de5-7fd4-465e-8122-4b3f616de346"
      }
    },
    "owner": "yashvardhan001-2"
  }
}
